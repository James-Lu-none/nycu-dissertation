FROM aflplusplus/aflplusplus:stable

RUN apt-get update && apt-get install -y \
    make cmake pkg-config wget curl git tmux libssl-dev xz-utils

WORKDIR /src

RUN git clone https://github.com/libarchive/libarchive.git && \
    cd libarchive && \
    git checkout v3.7.1

WORKDIR /src/libarchive
RUN mkdir build && cd build && \
    CC=afl-clang-lto cmake -DENABLE_SHARED=OFF -DENABLE_OPENSSL=OFF -DENABLE_TAR=OFF -DENABLE_CPIO=OFF .. && \
    make -j$(nproc)

COPY harness.c .

RUN afl-clang-lto -O3 harness.c -o target_normal \
    -I/src/libarchive/libarchive \
    /src/libarchive/build/libarchive/libarchive.a \
    /usr/local/lib/afl/libAFLDriver.a \
    -ldl -lpthread -lm -lz -llzma

RUN mkdir -p /workspace
RUN cp target_normal /workspace/target_normal

RUN mkdir -p /workspace/in
# Seed with a small tar entry
RUN echo "test" > test.txt && tar -cvf /workspace/in/seed.tar test.txt

WORKDIR /workspace
COPY run_all.sh /workspace/
RUN chmod +x run_all.sh
